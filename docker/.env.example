# Mowgli ROS2 v3 — Environment configuration
# Copy to .env and edit: cp .env.example .env

# ROS2 Domain ID — all containers must share the same value for DDS discovery
ROS_DOMAIN_ID=0

# IP of the mower Pi (only needed for ser2net mode)
MOWER_IP=10.0.0.161

# LiDAR serial port and baud rate (LD19 on hardware UART)
LIDAR_PORT=/dev/ttyS1
LIDAR_BAUD=230400

# Docker images (built by .github/workflows/{ros2,gui,sensors-*}-docker.yml)
MOWGLI_ROS2_IMAGE=ghcr.io/cedbossneo/mowglinext/mowgli-ros2:main
GPS_IMAGE=ghcr.io/cedbossneo/mowglinext/gps:main
LIDAR_IMAGE=ghcr.io/cedbossneo/mowglinext/lidar-ldlidar:main
MAVROS_IMAGE=ghcr.io/cedbossneo/mowglinext/mavros:main
GUI_IMAGE=ghcr.io/cedbossneo/mowglinext/mowglinext-gui:main
