# Build artifacts
build/
log/
*.pyc
__pycache__/
*.egg-info/

# IDE
.vscode/
.idea/
*.iml
*.code-workspace
.DS_Store

# ROS2
*.bag
*.db3
ros2/install

# PlatformIO (firmware)
.pio/

# Node modules (GUI)
node_modules/

# Docker
.env.local
# Site-specific runtime config — written by install/mowglinext.sh from
# docker/.env.example. The example is the only tracked template.
docker/.env
docker/.env.old.*
# Generated by install/mowglinext.sh from install/compose/*.yml fragments.
docker/docker-compose.yaml
docker/docker-compose.yaml.old.*
install/.preset
install/logs/

# Secrets
*.pem
*.key
credentials.json
.claude/worktrees

# Mow-session monitor logs — committed selectively via `git add -f` for
# golden / failure-case reference runs; default-ignored to avoid bloating
# the repo with every development test.
docker/logs/mow_sessions/*.jsonl
!docker/logs/mow_sessions/.gitkeep
.playwright-mcp/
exec
mobile-robots-empty.png
install/tests/
