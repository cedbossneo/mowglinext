{
  "name": "mowglinext-firebase-functions",
  "version": "1.0.0",
  "description": "Firebase Cloud Functions for the MowgliNext mobile companion app",
  "main": "lib/index.js",
  "type": "module",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "firebase-admin": "^13.0.0",
    "firebase-functions": "^6.0.0",
    "node-fetch": "^3.3.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "firebase-functions-test": "^3.4.0",
    "typescript": "^5.4.5",
    "vitest": "^3.0.0"
  }
}
