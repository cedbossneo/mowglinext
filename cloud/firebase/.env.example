# Cloudflare account that owns the tunnels and the mowgli.garden zone.
# Obtain from: Cloudflare Dashboard → Account Home → right sidebar "Account ID"
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id

# API token with scopes:
#   - Account / Cloudflare Tunnel: Edit
#   - Zone / DNS: Edit  (scoped to zone mowgli.garden)
# Create at: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token

# Zone ID for mowgli.garden (or your own domain).
# Obtain from: Cloudflare Dashboard → mowgli.garden → right sidebar "Zone ID"
CLOUDFLARE_ZONE_ID=your-cloudflare-zone-id

# Base domain for per-robot tunnel subdomains.
# Robots will be reachable at r-<robotId>.<TUNNEL_DOMAIN>
# Default: tunnel.mowgli.garden
TUNNEL_DOMAIN=tunnel.mowgli.garden
